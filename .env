# .env - Variables de entorno
# Archivo de configuración para diferentes entornos

# =============================================
# APLICACIÓN
# =============================================
APP_NAME="Sistema de Transporte"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# =============================================
# BASE DE DATOS
# =============================================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=NewTransporte
DB_USERNAME=postgres
DB_PASSWORD=Jadrian8
DB_SCHEMA=global
DB_DRIVER=pgsql

# =============================================
# SEGURIDAD
# =============================================
SESSION_NAME=transporte_session
SESSION_LIFETIME=7200
ENCRYPTION_KEY=tu_clave_secreta_aqui_de_32_caracteres

# =============================================
# ZONA HORARIA
# =============================================
TIMEZONE=America/La_Paz

# =============================================
# OPCIONES ADICIONALES
# =============================================
ITEMS_PER_PAGE=20
MAINTENANCE_MODE=false